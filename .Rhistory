#Projeto utilizando o Princípio da Inclusão e Exclusão no R com Base de Dados Financeira
# Autores: Carlos Canto e Paolo Storto
# Base: Prices and Yields of Brazilian Bonds - Marcelo Perlin (Tesouro Direto)
#-----------------------------------------------------------------------------------------
#1)- Carregar pacotes necessários para as configurações
if(!require("pacman")) install.packages("pacman")
library(pacman)
p_load(here, #acesso as dados de dentro do meu diretório
scales, #padronização de dados
bslib,  # criar interfaces de usuário (UI) modernas
plotly, #gráficos interativos
tidyverse, #organização de dados
shiny,  #cria aplicativos web interativos
readxl, #leitura de dados
bsicons #icones para o dashboard executivo
)
# 2. Preparação dos Dados
# Leitura direta do arquivo Excel usando readxl e here
df_bonds <- read_excel(here("Tesour.xlsx")) %>%    #Lê o arquivo excel no meu diretorio
mutate(
Data_inicial = as.Date(Data_inicial),                        #
Data_de_Vencimento = as.Date(Data_de_Vencimento),            #   TRANSFROMAÇÃO DAS MINHAS COLUNAS PARA
Rendimentos = as.numeric(Rendimentos),                       #             OS TIPOS CORRETOS
Preço_do_investimento = as.numeric(Preço_do_investimento)    #
) %>%
# Separação da Família do Título do seu SKU
separate(Tipo_de_investimento,
into = c("Familia_Investimento", "SKU_Investimento"),      #
sep = " ",                                                 #  SEPARANDO PARTE DOS INVESTIMENTOS QUE ESTAVAM JUNTOS
extra = "merge",                                           #    EM 2 PARTES (QUAL É O INVESTIMENTO E O SEU ID/SKU)
remove = FALSE) %>%                                        #
# Limpeza básica e ordenação cronológica
arrange(Data_inicial) %>%                                           #   ORGANIZAÇÃO DAS DATAS PARA NÃO HAVER DESVIO DE
drop_na(Rendimentos, Preço_do_investimento)                         #         DATAS OU INTERFERÊNCIA DAS DATAS
titulos_disponiveis <- unique(df_bonds$Familia_Investimento)          #UTILIZAÇÃO DE SOMENTE UM TÍTULO DE CADA INVESTIMENTO
# 3. Interface de Utilizador (UI) - NOVA ESTRUTURA EXECUTIVA
ui <- page_navbar(
title = "Intelligence Hub: Renda Fixa - Princípio da Inclusão e Exclusão", #TÍTULO DA INTERFACE
theme = bs_theme(version = 5, bootswatch = "flatly", primary = "#2C3E50", secondary = "#95a5a6"),   #QUAL O TEMA E COMO VAI SER O ASPECTO DO FRONT
sidebar = sidebar(
title = "Controles de Análise",
bg = "#f8f9fa",
selectInput("ativo_a", "Selecione a Família A:", choices = titulos_disponiveis, selected = titulos_disponiveis[1]),
selectInput("ativo_b", "Selecione a Família B:", choices = titulos_disponiveis, selected = titulos_disponiveis[2]),
sliderInput("meta_rendimento", "Meta de Rendimento Diário (>):",
min = 0, max = max(df_bonds$Rendimentos, na.rm = TRUE),
value = 0, step = 0.001),
dateRangeInput("periodo", "Período de Análise:",
start = min(df_bonds$Data_inicial),
end = max(df_bonds$Data_inicial)),
hr(),
helpText("O modelo analisa a probabilidade de o rendimento superar a meta, comparando categorias puras de investimento.")
),
nav_panel("Dashboard de Performance",
layout_column_wrap(
width = 1/4,
value_box(
title = "Probabilidade P(A)",
value = uiOutput("p_a_val"),
showcase = bsicons::bs_icon("graph-up-arrow"),
theme = "primary"
),
value_box(
title = "Probabilidade P(B)",
value = uiOutput("p_b_val"),
showcase = bsicons::bs_icon("graph-up"),
theme = "secondary"
),
value_box(
title = "Interseção P(A ∩ B)",
value = uiOutput("p_inter_val"),
showcase = bsicons::bs_icon("intersect"),
theme = "info"
),
value_box(
title = "União P(A ∪ B)",
value = uiOutput("p_uniao_val"),
showcase = bsicons::bs_icon("pie-chart-fill"),
theme = "success"
)
),
layout_columns(
card(
card_header("Evolução do Preço e Rendimento ao Longo do Tempo"),
plotlyOutput("grafico_serie_temporal", height = "400px")
),
card(
card_header("Matriz de Decisão & Correlação"),
uiOutput("texto_analise_critica")
)
)
),
nav_panel("Fundamentação Teórica",
card(
card_body(
h3("O Princípio da Inclusão e Exclusão em Finanças"),
p(strong("O grande diferencial desse projeto é mostrar a Análise de Diversificação:")),
p("Se a interseção P(A ∩ B) for muito alta, os ativos são altamente correlacionados e não protegem sua carteira. Se for baixa, você tem uma diversificação real."),
hr(),
withMathJax(p("$$P(A \\cup B) = P(A) + P(B) - P(A \\cap B)$$")),
tags$ul(
tags$li(strong("P(A) e P(B):"), "Probabilidade individual de cada título bater a meta de rendimento."),
tags$li(strong("Interseção P(A ∩ B):"), "Dias em que os dois ativos bateram a meta juntos."),
tags$li(strong("União P(A ∪ B):"), "A chance de pelo menos um ativo na sua estratégia ter sucesso.")
)
)
)
)
)
# 4. Lógica do Servidor (Server)
server <- function(input, output, session) {
# Filtro reativo
dados_filtrados <- reactive({
req(input$ativo_a, input$ativo_b, input$periodo)
df_bonds %>%
filter(
Familia_Investimento %in% c(input$ativo_a, input$ativo_b),
Data_inicial >= input$periodo[1],
Data_inicial <= input$periodo[2]
)
})
# Lógica centralizada para alimentar os novos blocos do dashboard
stats <- reactive({
df_analise <- dados_filtrados()
df_wide <- df_analise %>%
select(Data_inicial, Familia_Investimento, Rendimentos) %>%                                        # PEGA OS VALORES
pivot_wider(names_from = Familia_Investimento, values_from = Rendimentos, values_fn = mean) %>%      # E FAZ O PRINCIP
drop_na()                                                                                          # DA INC/EXC
if(nrow(df_wide) == 0) return(NULL)
total_dias <- nrow(df_wide)
meta <- input$meta_rendimento
ativo_a <- input$ativo_a        #ESSE SERIA O ATIVO P(A)
ativo_b <- input$ativo_b        #ESSE É O ATIVO P(B)
dias_A <- sum(df_wide[[ativo_a]] > meta, na.rm = TRUE)   #SOMA TODOS OS DIAS P(A)
dias_B <- sum(df_wide[[ativo_b]] > meta, na.rm = TRUE)   #SOMA TODOS OS DIAS P(B)
dias_A_e_B <- sum(df_wide[[ativo_a]] > meta & df_wide[[ativo_b]] > meta, na.rm = TRUE)   #SOMA TODOS OS DIAS (P(A) INTERSEÇÃO P(B))
p_A <- dias_A / total_dias                 #ESSE SERIA P(A)
p_B <- dias_B / total_dias                 #ESSE É O P(B)
p_A_inter_B <- dias_A_e_B / total_dias     #ESSE É O P(A) INTERSEÇÃO P(B) DIVIDIDO PELO TOTAL DE DIAS
p_A_uniao_B <- p_A + p_B - p_A_inter_B     #ESSE É O PRINCIPIO DA INCLUSAO E EXCLUSAO EM PRÁTICA
# Cálculo de correlação adicionado para a matriz de decisão
correlacao <- cor(df_wide[[ativo_a]], df_wide[[ativo_b]])
list(pa = p_A, pb = p_B, pi = p_A_inter_B, pu = p_A_uniao_B, corr = correlacao, n = total_dias)
})
# Renderização das Caixas de Valor (Value Boxes)
output$p_a_val <- renderText({ req(stats()); percent(stats()$pa, 0.01) })
output$p_b_val <- renderText({ req(stats()); percent(stats()$pb, 0.01) })
output$p_inter_val <- renderText({ req(stats()); percent(stats()$pi, 0.01) })
output$p_uniao_val <- renderText({ req(stats()); percent(stats()$pu, 0.01) })
# Matriz de Decisão e Análise Crítica
output$texto_analise_critica <- renderUI({
res <- stats()
if(is.null(res)) return(HTML("<div class='alert alert-warning'>Sem dados coincidentes no período.</div>"))
status_div <- if(res$corr > 0.7) "ALTA CORRELAÇÃO (Baixa Diversificação)" else "BOA DIVERSIFICAÇÃO"
HTML(paste0(
"<div style='padding:10px; font-size: 15px;'>",
"<p><strong>Dias Analisados em Comum:</strong> ", res$n, "</p>",
"<p><strong>Correlação de Pearson:</strong> ", round(res$corr, 2), "</p>",
"<div style='margin-bottom: 15px;' class='badge bg-warning text-dark'>", status_div, "</div>",
"<div style='background-color: #ecf0f1; padding: 15px; border-radius: 8px; border-left: 5px solid #18bc9c;'>",
"<strong>P(A ∪ B) = P(A) + P(B) - P(A ∩ B)</strong><br><br>",
"A probabilidade de <em>pelo menos um</em> dos investimentos bater a meta é de: <strong>", percent(res$pu, 0.01), "</strong>",
"</div></div>"
))
})
# Gráfico Plotly
output$grafico_serie_temporal <- renderPlotly({
df_plot <- dados_filtrados()
p <- ggplot(df_plot, aes(x = Data_inicial, y = Preço_do_investimento, color = Familia_Investimento,
text = paste("Data:", format(Data_inicial, "%d/%m/%Y"),
"<br>Título:", Tipo_de_investimento,
"<br>Preço: R$", round(Preço_do_investimento, 2),
"<br>Rendimento:", round(Rendimentos, 4)))) +
geom_line(alpha = 0.8, linewidth = 0.8) +
geom_point(alpha = 0.4, size = 1) +
scale_color_manual(values = c("#2980b9", "#c0392b")) +
labs(x = "Data", y = "Preço", color = "Família") +
theme_minimal() +
theme(legend.position = "bottom")
ggplotly(p, tooltip = "text") %>% layout(hovermode = "x unified")
})
}
# 5. Rodar App
shinyApp(ui = ui, server = server)   #RODANDO O APP
rm(list= ls())
